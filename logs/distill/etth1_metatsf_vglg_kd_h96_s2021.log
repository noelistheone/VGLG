  distill_lambda_mse: 1.0
  distill_lambda_trend: 0.0002
  distill_lambda_freq: 0.001
  distill_lambda_diff: 1.0
  distill_warmup_epochs: 1
seed: 2021
device: cuda
project: vglg-tsf
run_name: null
tag: distill

